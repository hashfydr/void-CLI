rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }


    function isOwner(authorField) {
      return isAuthenticated() && request.auth.uid == resource.data[authorField];
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isModerator() {
      return isAuthenticated() && request.auth.token.email == 'adonisbeing@gmail.com';
    }

    // ─── Users Collection ───────────────────────────────────────
    match /users/{userId} {
      // Users can only read their own profile; create only their own doc
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['email', 'uid', 'username'])
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // Users cannot delete their profiles
    }

    // ─── Posts Collection ───────────────────────────────────────
    match /posts/{postId} {
      // Only verified users can read and create posts
      allow read: if isAuthenticated() && isVerified();
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.resource.data.keys().hasAll(['content', 'createdAt', 'author', 'username'])
                    && request.resource.data.author == request.auth.uid
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 2000;
      // Only the original author can update their own posts
      allow update: if isOwner('author');
      allow delete: if isOwner('author') || isModerator();
    }

    // ─── Messages Collection (Chatroom) ─────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated() && isVerified();
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.resource.data.keys().hasAll(['text', 'createdAt', 'authorId', 'authorUsername'])
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000;
      // Only the original author can update their own messages
      allow update: if isOwner('authorId');
      allow delete: if isOwner('authorId') || isModerator();
    }

    // ─── Comments Collection ────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isAuthenticated() && isVerified();
      allow create: if isAuthenticated()
                    && isVerified()
                    && request.resource.data.keys().hasAll(['postId', 'text', 'createdAt', 'authorId', 'authorUsername'])
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000;
      // Only the original author can update their own comments
      allow update: if isOwner('authorId');
      allow delete: if isOwner('authorId') || isModerator();
    }

    // ─── Deny everything else by default ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
